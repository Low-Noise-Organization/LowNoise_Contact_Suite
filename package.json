{
  "name": "low-noise-contact-suite",
  "version": "1.0.0",
  "description": "Multichannel contact framework – plug & play, no backend required.",
  "main": "dist/low-noise-contact-suite.js",
  "module": "dist/low-noise-contact-suite.esm.js",
  "types": "dist/index.d.ts",
  "style": "low-noise-contact-suite.css",
  "files": [
    "dist/",
    "src/angular/",
    "low-noise-contact-suite.css",
    "proxies/",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css",
    "src/vanilla/auto-init.ts"
  ],
  "exports": {
    ".": {
      "import": "./dist/low-noise-contact-suite.esm.js",
      "require": "./dist/low-noise-contact-suite.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/low-noise-contact-suite.esm.js"
    },
    "./react": {
      "import": "./dist/react.esm.js",
      "require": "./dist/react.js",
      "types": "./dist/react/index.d.ts",
      "default": "./dist/react.esm.js"
    },
    "./angular": {
      "types": "./src/angular/index.d.ts",
      "import": "./src/angular/index.ts",
      "default": "./src/angular/index.ts"
    },
    "./vanilla/auto-init": {
      "import": "./dist/vanilla-auto-init.esm.js",
      "require": "./dist/vanilla-auto-init.js",
      "default": "./dist/vanilla-auto-init.esm.js"
    },
    "./low-noise-contact-suite.css": "./low-noise-contact-suite.css",
    "./proxies/*": "./proxies/*"
  },
  "scripts": {
    "build": "node node_modules/typescript/bin/tsc --emitDeclarationOnly && node node_modules/rollup/dist/bin/rollup -c",
    "dev": "node node_modules/typescript/bin/tsc --watch",
    "test": "node node_modules/jest/bin/jest.js",
    "test:coverage": "node node_modules/jest/bin/jest.js --coverage",
    "test:integration": "node node_modules/cypress/bin/cypress run",
    "lint": "node node_modules/eslint/bin/eslint.js src/ tests/ --ext .ts,.tsx,.js",
    "lint:fix": "node node_modules/eslint/bin/eslint.js src/ tests/ --ext .ts,.tsx,.js --fix",
    "format": "node node_modules/prettier/bin/prettier.cjs --write \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,js}\" \"*.{js,json,css}\"",
    "format:check": "node node_modules/prettier/bin/prettier.cjs --check \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,js}\" \"*.{js,json,css}\"",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0",
    "@angular/core": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "@angular/core": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Low-Noise-Organization/LowNoise_Contact_Suite"
  },
  "keywords": [
    "contact-form",
    "whatsapp",
    "emailjs",
    "discord",
    "telegram",
    "slack",
    "webhook",
    "react",
    "angular",
    "vanilla-js",
    "typescript"
  ],
  "author": "low-noise",
  "license": "MIT",
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "@storybook/addon-essentials": "^8.0.0",
    "@storybook/html": "^8.0.0",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "cypress": "^13.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.2.0",
    "rollup": "^4.0.0",
    "ts-jest": "^29.1.0",
    "tslib": "^2.8.1",
    "typescript": "^5.3.0"
  }
}
