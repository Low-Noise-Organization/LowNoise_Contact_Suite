{
  "name": "low-noise-contact-suite",
  "version": "1.0.0",
  "description": "Multichannel contact framework – plug & play, no backend required.",
  "main": "dist/low-noise-contact-suite.js",
  "module": "dist/low-noise-contact-suite.esm.js",
  "types": "dist/index.d.ts",
  "style": "low-noise-contact-suite.css",
  "files": [
    "dist/",
    "low-noise-contact-suite.css",
    "proxies/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --emitDeclarationOnly && rollup -c",
    "dev": "tsc --watch",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:integration": "cypress run",
    "lint": "eslint src/ tests/ --ext .ts,.js",
    "lint:fix": "eslint src/ tests/ --ext .ts,.js --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.{ts,js}\" \"*.{js,json,css}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.{ts,js}\" \"*.{js,json,css}\"",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "keywords": [
    "contact-form",
    "whatsapp",
    "emailjs",
    "discord",
    "telegram",
    "slack",
    "webhook",
    "vanilla-js",
    "typescript"
  ],
  "author": "Tu nombre",
  "license": "MIT",
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "@storybook/addon-essentials": "^8.0.0",
    "@storybook/html": "^8.0.0",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "cypress": "^13.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.2.0",
    "rollup": "^4.0.0",
    "ts-jest": "^29.1.0",
    "tslib": "^2.8.1",
    "typescript": "^5.3.0"
  }
}
